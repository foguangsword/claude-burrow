# ClaudeBurrow — Storage Backend Credentials
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Storage type: oss | r2 | s3 | custom
CLAUDEBURROW_STORAGE_TYPE=oss

# Endpoint URL (without bucket name)
CLAUDEBURROW_STORAGE_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# Bucket name
CLAUDEBURROW_STORAGE_BUCKET=claude-burrow

# Region (OSS: oss-cn-hangzhou, R2: auto)
CLAUDEBURROW_STORAGE_REGION=oss-cn-hangzhou

# Access credentials
CLAUDEBURROW_STORAGE_ACCESS_KEY_ID=your-access-key-id
CLAUDEBURROW_STORAGE_SECRET_ACCESS_KEY=your-secret-access-key

# Encryption passphrase (optional — you can enter it interactively)
# CLAUDEBURROW_PASSPHRASE=your-passphrase

# Salt for PBKDF2 key derivation (optional — auto-synced via cloud salt.dat)
# Salt is automatically generated on first setup and uploaded to your bucket.
# Other devices download it automatically. Only set this to force a specific value.
# CLAUDEBURROW_SALT=your-base64-salt

# Device name (optional — defaults to hostname)
# CLAUDEBURROW_DEVICE_NAME=my-laptop
